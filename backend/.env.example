# Database
MONGO_URI=mongodb://mongo:27017/task_manager?directConnection=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=

# JWT
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_VERIFIED_SECRET=replace_with_strong_verified_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_VERIFIED_EXPIRES_IN=5m

# App
PORT=8001
CLIENT_URL=http://localhost:5173
ADMIN_INVITE_TOKEN=replace_if_used

# Email (Gmail app password recommended)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
